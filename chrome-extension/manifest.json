{
  "manifest_version": 2,
  "name": "React Slide to PPTX",
  "version": "1.0.0",
  "description": "将 React JSX 代码转换为 PPTX 文件",
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_title": "React Slide → PPTX"
  },
  "permissions": ["downloads"],
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'"
}
